# =========================
# APP
# =========================
APP_NAME=braum
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.0.1-dev
DEV=1

API_HOST=0.0.0.0
API_PORT=8000
API_EXTERNAL_PORT=8000

CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# =========================
# SECURITY / AUTH
# =========================
SECRET_KEY=troque-esta-chave-em-producao
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Guest mode (modo Geral sem login)
GUEST_SESSION_MAX_QUESTIONS=10
GUEST_SESSION_TTL_SECONDS=86400

# =========================
# POSTGRES
# =========================
POSTGRES_DB=braum
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/braum

# =========================
# REDIS
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_EXTERNAL_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery usando Redis
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =========================
# CELERY / FLOWER
# =========================
FLOWER_EXTERNAL_PORT=5555
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# =========================
# VECTOR DB - QDRANT
# =========================
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://qdrant:6333
QDRANT_EXTERNAL_PORT=6333
QDRANT_COLLECTION_DOCUMENTS=documents

# =========================
# STORAGE - MINIO
# =========================
STORAGE_PROVIDER=minio
STORAGE_BUCKET=braum-files
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio123
MINIO_EXTERNAL_PORT=9000
MINIO_CONSOLE_EXTERNAL_PORT=9001

# Se seu código usar S3 style
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000

# =========================
# LLM LOCAL - OLLAMA
# =========================
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Embeddings locais
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# =========================
# SQL MODE
# =========================
SQL_ALLOWED_SCHEMAS=public
SQL_ALLOWED_TABLES=
SQL_DEFAULT_LIMIT=100
SQL_MAX_LIMIT=500
SQL_TIMEOUT_SECONDS=30
SQL_READONLY=true

# =========================
# DOCUMENT INGESTION / RAG
# =========================
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.4
RAG_MAX_CHUNKS=8
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx,.csv,.xlsx
RAG_MAX_FILE_SIZE_MB=25

# =========================
# LOGGING / OBSERVABILITY
# =========================
LOG_LEVEL=INFO
LOG_JSON=false
REQUEST_TIMEOUT_SECONDS=60

# =========================
# FEATURE FLAGS
# =========================
ENABLE_GENERAL_MODE=true
ENABLE_RAG_MODE=true
ENABLE_SQL_MODE=true
ENABLE_USER_REGISTRATION=true
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_FLOWER=true

# =========================
# OPTIONAL / DESLIGADO
# =========================
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_EXTERNAL_PORT=5672
RABBITMQ_MANAGEMENT_EXTERNAL_PORT=15672